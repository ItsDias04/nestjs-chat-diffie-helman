              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "access-token": []
          }
        ],
        "summary": "Отключить Brickell–McCurley для пользователя",
        "tags": [
          "auth"
        ]
      }
    },
    "/chats": {
      "get": {
        "description": "Возвращает список всех чатов текущего пользователя",
