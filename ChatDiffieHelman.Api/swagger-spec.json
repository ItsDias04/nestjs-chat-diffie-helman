{
  "openapi": "3.0.0",
  "paths": {
    "/users/all": {
      "get": {
        "description": "Возвращает список всех зарегистрированных пользователей",
        "operationId": "UserController_getAllUsers",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Список пользователей",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserDto"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "access-token": []
          }
        ],
        "summary": "Получить всех пользователей",
        "tags": [
          "users"
        ]
      }
    },
    "/users/me": {
      "get": {
        "description": "Возвращает данные авторизованного пользователя",
        "operationId": "UserController_getMe",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Данные текущего пользователя",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "access-token": []
          }
        ],
        "summary": "Получить информацию о текущем пользователе",
        "tags": [
          "users"
        ]
      }
    },
    "/users/{id}": {
      "get": {
        "description": "Возвращает информацию о конкретном пользователе",
        "operationId": "UserController_getUser",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "UUID пользователя",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Данные пользователя",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserDto"
                }
              }
            }
          },
          "404": {
            "description": "Пользователь не найден"
          }
        },
        "security": [
          {
            "access-token": []
          }
        ],
        "summary": "Получить пользователя по ID",
        "tags": [
          "users"
        ]
      }
    },
    "/users/registration": {
      "post": {
        "description": "Создает нового пользователя в системе",
        "operationId": "UserController_registerUser",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Зарегистрированный пользователь",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserDto"
                }
              }
            }
          },
          "400": {
            "description": "Некорректные данные"
          },
          "409": {
            "description": "Пользователь с таким email уже существует"
          }
        },
        "summary": "Регистрация нового пользователя",
        "tags": [
          "users"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "description": "Аутентификация пользователя с email и паролем. Может потребовать дополнительную идентификацию (Fiat-Shamir или BMC).",
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешный вход или требуется дополнительная идентификация",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "nullable": true,
                      "description": "JWT токен (null если требуется дополнительная идентификация)"
                    },
                    "fiat_required": {
                      "type": "boolean",
                      "description": "Требуется ли идентификация Fiat-Shamir"
                    },
                    "fiat_session_id": {
                      "type": "string",
                      "nullable": true,
                      "description": "ID сессии Fiat-Shamir"
                    },
                    "bmc_required": {
                      "type": "boolean",
                      "description": "Требуется ли идентификация Brickell–McCurley"
                    },
                    "bmc_session_id": {
                      "type": "string",
                      "nullable": true,
                      "description": "ID сессии BMC"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Неверные учетные данные"
          }
        },
        "summary": "Вход пользователя",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/uniauth/start": {
      "post": {
        "description": "Получает Token 1 в UniAuth и возвращает redirectUrl на bridge страницу UniAuth.",
        "operationId": "AuthController_startUniAuth",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {},
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ссылка для перехода на UniAuth bridge",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "redirectUrl": {
                      "type": "string",
                      "example": "http://localhost:4200/oauth2/external-redirect/<token1>"
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Начать вход через UniAuth",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/uniauth/callback": {
      "get": {
        "description": "Принимает token3, валидирует его через UniAuth и редиректит пользователя обратно во внешний frontend.",
        "operationId": "AuthController_uniAuthCallback",
        "parameters": [
          {
            "name": "token3",
            "required": false,
            "in": "query",
            "description": "Одноразовый Token 3 от UniAuth bridge",
            "schema": {}
          }
        ],
        "responses": {
          "302": {
            "description": "Редирект на login страницу web-клиента с результатом входа"
          },
          "502": {
            "description": "Fallback HTML-страница при ошибке redirect или сети"
          }
        },
        "summary": "Callback входа через UniAuth",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/fiat/start": {
      "post": {
        "description": "Первый шаг протокола идентификации Fiat-Shamir",
        "operationId": "AuthController_fiatStart",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "sid": {
                    "type": "string",
                    "description": "ID сессии"
                  },
                  "t": {
                    "type": "string",
                    "description": "Обязательство (commitment) t = r² mod n"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Возвращает вызов (challenge)",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "c": {
                      "type": "number",
                      "description": "Случайный вызов (0 или 1)"
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Начать идентификацию Fiat-Shamir",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/fiat/finish": {
      "post": {
        "description": "Второй шаг протокола идентификации Fiat-Shamir",
        "operationId": "AuthController_fiatFinish",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "sid": {
                    "type": "string",
                    "description": "ID сессии"
                  },
                  "r": {
                    "type": "string",
                    "description": "Ответ r = x·c + y mod n"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JWT токен при успешной идентификации",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "nullable": true,
                      "description": "JWT токен доступа"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Идентификация не пройдена"
          }
        },
        "summary": "Завершить идентификацию Fiat-Shamir",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/bmc/start": {
      "post": {
        "description": "Первый шаг протокола идентификации Brickell–McCurley",
        "operationId": "AuthController_bmcStart",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "sid": {
                    "type": "string",
                    "description": "ID сессии"
                  },
                  "a": {
                    "type": "string",
                    "description": "Обязательство a = g^k mod n"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Возвращает случайный вызов",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "r": {
                      "type": "number",
                      "description": "Случайное число вызова"
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Начать идентификацию Brickell–McCurley",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/bmc/finish": {
      "post": {
        "description": "Второй шаг протокола идентификации Brickell–McCurley",
        "operationId": "AuthController_bmcFinish",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "sid": {
                    "type": "string",
                    "description": "ID сессии"
                  },
                  "e": {
                    "type": "string",
                    "description": "Ответ e = k + r·x mod (n-1)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JWT токен при успешной идентификации",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "nullable": true,
                      "description": "JWT токен доступа"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Идентификация не пройдена"
          }
        },
        "summary": "Завершить идентификацию Brickell–McCurley",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/fiat/enable/{userId}": {
      "post": {
        "description": "Активация протокола Fiat-Shamir идентификации",
        "operationId": "AuthController_enableFiatForUser",
        "parameters": [
          {
            "name": "userId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "v": {
                    "type": "string",
                    "description": "Публичный ключ v = s² mod n"
                  },
                  "n": {
                    "type": "string",
                    "description": "Модуль n (произведение двух простых чисел)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Сообщение об успехе",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "security": [
          {
            "access-token": []
          }
        ],
        "summary": "Включить Fiat-Shamir для пользователя",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/fiat/disable/{userId}": {
      "post": {
        "description": "Деактивация протокола Fiat-Shamir идентификации",
        "operationId": "AuthController_disableFiatForUser",
        "parameters": [
          {
            "name": "userId",
