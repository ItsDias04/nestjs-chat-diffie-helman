  "info": {
    "title": "Chat Diffie-Hellman API",
    "description": "\n      API для чата с криптографической защитой.\n      \n      ## Возможности:\n      - 🔐 Аутентификация JWT\n      - 🔑 Протокол Fiat-Shamir идентификации\n      - 🛡️ Протокол Brickell–McCurley идентификации  \n      - 💬 Управление чатами и сообщениями\n      - 🔒 Обмен ключами Diffie-Hellman для шифрования\n      - 👥 Система приглашений\n      \n      ## Как начать:\n      1. Зарегистрируйтесь через `POST /users/registration`\n      2. Войдите через `POST /auth/login`\n      3. Используйте полученный токен для авторизации (кнопка \"Authorize\" вверху)\n      \n      ## JSON документация доступна по адресу:\n      - Swagger UI: `/api`\n      - JSON схема: `/api-json`\n      - YAML схема: `/api-yaml`\n    ",
    "version": "1.0.0",
    "contact": {
      "name": "API Support",
      "url": "",
      "email": "support@example.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "tags": [
    {
      "name": "auth",
      "description": "Эндпоинты аутентификации и криптографической идентификации"
    },
    {
      "name": "users",
      "description": "Управление пользователями"
    },
    {
      "name": "chats",
      "description": "Управление чатами"
    },
    {
      "name": "messages",
      "description": "Управление сообщениями"
    },
    {
      "name": "invites",
      "description": "Управление приглашениями в чаты"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "in": "header",
        "description": "Введите JWT токен, полученный после авторизации"
      }
    },
    "schemas": {
      "UserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "ID пользователя (UUID)",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "example": "John Doe",
            "description": "Имя пользователя"
          },
          "email": {
            "type": "string",
            "example": "john.doe@example.com",
            "description": "Email пользователя"
          },
          "fiat_enabled": {
            "type": "boolean",
            "example": true,
            "description": "Включена ли функция Fiat"
          },
          "bmc_enabled": {
            "type": "boolean",
            "example": false,
            "description": "Включен ли протокол Brickell–McCurley"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "fiat_enabled",
          "bmc_enabled"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "John Doe",
            "description": "Имя пользователя"
          },
          "email": {
            "type": "string",
            "example": "john.doe@example.com",
            "description": "Email пользователя"
          },
          "password": {
            "type": "string",
            "example": "strongPassword123",
            "description": "Пароль пользователя"
          }
        },
        "required": [
          "username",
          "email",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "john.doe@example.com",
            "description": "Email пользователя"
          },
          "password": {
            "type": "string",
            "example": "strongPassword123",
            "description": "Пароль пользователя"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ChatDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "ID чата (UUID)",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "example": "Chat Room 1",
            "description": "Название чата"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "MessageDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "ID сообщения (UUID)",
            "format": "uuid"
          },
          "chatId": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "ID чата (UUID)",
            "format": "uuid"
          },
          "chat": {
            "description": "Информация о чате",
            "allOf": [
              {
                "$ref": "#/components/schemas/ChatDto"
              }
            ]
          },
          "userId": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "ID пользователя (UUID)",
            "format": "uuid"
          },
          "user": {
            "description": "Информация о пользователе, отправившем сообщение",
            "allOf": [
              {
                "$ref": "#/components/schemas/UserDto"
              }
            ]
          },
          "content": {
            "type": "string",
            "example": "Hello, world!",
            "description": "Содержимое сообщения"
          },
          "timestamp": {
            "type": "string",
            "example": "2023-10-05T14:48:00.000Z",
            "description": "Временная метка сообщения",
            "format": "date-time"
          },
          "reviewed": {
            "type": "boolean",
            "example": true,
            "description": "Флаг, указывающий, было ли сообщение просмотрено"
          },
          "type": {
            "type": "string",
            "example": "text",
            "description": "Тип сообщения",
            "enum": [
              "text",
              "diffie-hellman-key",
              "system"
            ]
          },
          "encryptionKeyIndex": {
            "type": "number",
            "example": 0,
            "description": "Порядковый номер ключа шифрования в чате",
            "nullable": true
          }
        },
        "required": [
          "id",
          "chatId",
          "userId",
          "content",
          "timestamp",
          "reviewed",
          "type"
        ]
      },
      "InviteCreateDto": {
        "type": "object",
        "properties": {
          "chatId": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "ID чата (UUID)",
            "format": "uuid"
          },
          "userReceiverId": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "ID пользователя-получателя (UUID)",
            "format": "uuid"
          }
        },
        "required": [
          "chatId",
          "userReceiverId"
        ]
      },
      "InviteDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "ID приглашения (UUID)",
            "format": "uuid"
          },
          "chatId": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174001",
            "description": "ID чата (UUID)",
            "format": "uuid"
          },
          "chat": {
            "description": "Информация о чате",
            "allOf": [
              {
                "$ref": "#/components/schemas/ChatDto"
              }
            ]
          },
          "userSenderId": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174002",
            "description": "ID отправителя (UUID)",
            "format": "uuid"
          },
          "userSender": {
            "description": "Информация об отправителе приглашения",
            "allOf": [
              {
                "$ref": "#/components/schemas/UserDto"
              }
            ]
          },
          "userReceiverId": {
            "type": "object",
            "example": "123e4567-e89b-12d3-a456-426614174003",
            "description": "ID получателя (UUID)",
            "format": "uuid",
            "nullable": true
          },
          "userReceiver": {
            "description": "Информация о получателе приглашения",
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/UserDto"
              }
            ]
          },
          "status": {
            "type": "string",
            "example": "pending",
            "description": "Статус приглашения",
            "enum": [
              "pending",
              "accepted",
              "declined"
            ]
          },
          "createdAt": {
            "type": "string",
            "example": "2023-03-15T12:00:00Z",
            "description": "Дата создания приглашения",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "example": "2023-03-15T12:00:00Z",
            "description": "Дата обновления приглашения",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "chatId",
          "userSenderId",
          "userReceiverId",
          "status",
          "createdAt",
          "updatedAt"
        ]
      },
      "InviteRespondDto": {
        "type": "object",
        "properties": {
          "inviteId": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "ID приглашения (UUID)",
            "format": "uuid"
          },
          "accept": {
            "type": "boolean",
            "example": true,
            "description": "Признак принятия приглашения"
          }
        },
        "required": [
          "inviteId",
          "accept"
        ]
      }
    }
  },
  "security": [
    {
      "access-token": []
    }
  ]
}